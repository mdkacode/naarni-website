{
  "installCommand": "npm install --force",
  "rewrites": [
    {
      "source": "/api/v1/vehicles/filter",
      "destination": "/api/vehicles/filter"
    },
    {
      "source": "/api/v1/:path*",
      "destination": "https://api.internal.naarni.com/api/v1/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/api/:path*",
      "headers": [
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        },
        {
          "key": "Access-Control-Allow-Methods",
          "value": "GET, POST, PUT, DELETE, OPTIONS"
        },
        {
          "key": "Access-Control-Allow-Headers",
          "value": "Content-Type, Authorization, x-device-id, x-platform"
        }
      ]
    }
  ]
}
